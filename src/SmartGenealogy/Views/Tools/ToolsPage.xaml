<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage
    x:Class="SmartGenealogy.Views.Tools.ToolsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:SmartGenealogy.Views.Base"
    xmlns:controls="clr-namespace:SmartGenealogy.Controls"
    xmlns:fonticons="clr-namespace:SmartGenealogy.Resources.FontIcons"
    xmlns:localization="clr-namespace:SmartGenealogy.Resources.Translations"
    xmlns:viewModel="clr-namespace:SmartGenealogy.ViewModels.Tools"
    x:DataType="{viewModel:ToolsPageViewModel}"
    BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
    BaseTitle="{localization:Translate LabelTools}"
    BaseTitleColor="{DynamicResource BaseTextColor}">

    <base:BasePage.PageContent>
        <Grid RowDefinitions="Auto,Auto,Auto">

            <!--  Fact types  -->
            <StackLayout Grid.Row="1" Margin="20">
                <Label
                    FontSize="17"
                    HorizontalOptions="Start"
                    Style="{StaticResource Title2}"
                    Text="{localization:Translate LabelFactTypes}"
                    VerticalOptions="Center"
                    VerticalTextAlignment="Center" />

                <!--  Manage fact types  -->
                <Grid Padding="0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                    </Grid.ColumnDefinitions>
                    <Label
                        FontFamily="MaterialDesign"
                        FontSize="22"
                        HorizontalOptions="Start"
                        Text="{x:Static fonticons:MaterialDesignIcons.Event}"
                        TextColor="{DynamicResource PrimaryColor}"
                        VerticalOptions="Center" />

                    <Label
                        Grid.Column="1"
                        FontSize="15"
                        HorizontalOptions="Start"
                        Text="{localization:Translate LabelManageFactTypes}"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />

                    <Label
                        Grid.Column="2"
                        FontFamily="IonIcons"
                        FontSize="15"
                        HorizontalOptions="End"
                        HorizontalTextAlignment="Center"
                        Text="{x:Static fonticons:IonIcons.ChevronRight}"
                        TextColor="{DynamicResource BaseIconColor}"
                        VerticalOptions="Center" />

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenFactTypesCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </StackLayout>
        </Grid>
    </base:BasePage.PageContent>
</base:BasePage>