<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage
    x:Class="SmartGenealogy.Views.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:SmartGenealogy.Views.Base"
    xmlns:localization="clr-namespace:SmartGenealogy.Resources.Translations"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModel="clr-namespace:SmartGenealogy.ViewModels.Settings"
    x:Name="settingsPage"
    x:DataType="{viewModel:SettingsPageViewModel}"
    BackgroundColor="{DynamicResource BasePageColor}"
    BaseTitle="{Binding Title}"
    BaseTitleColor="{StaticResource BaseTextColor}">

    <base:BasePage.PageContent>
        <Grid RowDefinitions="Auto,Auto,Auto">


            <!--  SETTINGS  -->
            <StackLayout
                Grid.Row="2"
                Margin="20"
                VerticalOptions="Fill">
                <Label
                    FontSize="17"
                    HorizontalOptions="Start"
                    Style="{StaticResource Title2}"
                    Text="{localization:Translate LabelAppSettings}"
                    VerticalOptions="Center"
                    VerticalTextAlignment="Center" />

                <Grid Padding="0,7" ColumnDefinitions="*,Auto">
                    <Label
                        IsEnabled="{Binding EnableDarkModeSwitch, Mode=TwoWay}"
                        Style="{StaticResource HeaderStyle}"
                        Text="{localization:Translate LabelOpenLastDatabase}" />
                    <Switch
                        x:Name="openLastDatabaseSwitch"
                        Grid.Column="1"
                        HorizontalOptions="End"
                        IsToggled="{Binding OpenLastDatabaseToggled}">
                        <Switch.Behaviors>
                            <toolkit:EventToCommandBehavior
                                BindingContext="{Binding Source={x:Reference settingsPage}, Path=BindingContext}"
                                Command="{Binding ToggleOpenLastDatabaseCommand}"
                                CommandParameter="{Binding Source={x:Reference openLastDatabaseSwitch}, Path=IsToggled}"
                                EventName="Toggled" />
                        </Switch.Behaviors>
                    </Switch>
                </Grid>

                <Rectangle Fill="{DynamicResource BaseSeparatorColor}" HeightRequest="0.5" />

                <Grid Padding="0,7" ColumnDefinitions="*,Auto">
                    <Label
                        IsEnabled="{Binding EnableDarkModeSwitch, Mode=TwoWay}"
                        Style="{StaticResource HeaderStyle}"
                        Text="{localization:Translate LabelDarkmode}" />
                    <Switch
                        x:Name="darkModeSwitch"
                        Grid.Column="1"
                        HorizontalOptions="End"
                        IsToggled="{Binding DarkModeSwitchToggled}">
                        <Switch.Behaviors>
                            <toolkit:EventToCommandBehavior
                                BindingContext="{Binding Source={x:Reference settingsPage}, Path=BindingContext}"
                                Command="{Binding ToggleDarkModeCommand}"
                                CommandParameter="{Binding Source={x:Reference darkModeSwitch}, Path=IsToggled}"
                                EventName="Toggled" />
                        </Switch.Behaviors>
                    </Switch>
                </Grid>
            </StackLayout>
        </Grid>
        <!--<VerticalStackLayout Padding="30,0" Spacing="25">
        -->
