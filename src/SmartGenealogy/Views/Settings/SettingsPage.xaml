<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartGenealogy.Views.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:SmartGenealogy.Models"
    xmlns:viewmodel="clr-namespace:SmartGenealogy.ViewModels.Settings"
    Title="Settings"
    x:DataType="viewmodel:SettingsViewModel">
    <VerticalStackLayout>

        <Label
            FontSize="Medium"
            HorizontalOptions="Center"
            Text="Images"
            VerticalOptions="Center" />

        <Label Text="Tesseract language file location" VerticalOptions="Center" />
        <Entry Text="{Binding Settings.TesseractLanguageFileLocation}" />

        <Label
            FontSize="Medium"
            HorizontalOptions="Center"
            Text="Places"
            VerticalOptions="Center" />

        <Label Text="Geocodio API Key" VerticalOptions="Center" />
        <Entry Text="{Binding Settings.GeocodioApiKey}" />
        <Label Text="Places Base Directory" VerticalOptions="Center" />
        <Entry Text="{Binding Settings.PlacesBaseDirectory}" />
    </VerticalStackLayout>
</ContentPage>