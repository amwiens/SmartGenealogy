<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SmartGenealogy.Views.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:SmartGenealogy.Models"
    xmlns:viewmodel="clr-namespace:SmartGenealogy.ViewModels.Settings"
    Title="Settings"
    x:DataType="viewmodel:SettingsViewModel">
    <VerticalStackLayout>

        <Label
            FontSize="Medium"
            HorizontalOptions="Center"
            Text="Images"
            VerticalOptions="Center" />

        <Label Text="Tesseract language file location" VerticalOptions="Center" />
        <Grid ColumnDefinitions="*,Auto">
            <Entry Text="{Binding TesseractLanguageFileLocation}" />
            <Button
                Grid.Column="1"
                Command="{Binding PickTesseractFolderCommand}"
                Text="Get Folder" />
        </Grid>

        <Label
            FontSize="Medium"
            HorizontalOptions="Center"
            Text="Places"
            VerticalOptions="Center" />

        <Label Text="Geocodio API Key" VerticalOptions="Center" />
        <Entry Text="{Binding GeocodioApiKey}" />
        <Label Text="Places Base Directory" VerticalOptions="Center" />
        <Grid ColumnDefinitions="*,Auto">
            <Entry Text="{Binding PlacesBaseDirectory}" />
            <Button
                Grid.Column="1"
                Command="{Binding PickPlacesBaseFolderCommand}"
                Text="Get Folder" />
        </Grid>
    </VerticalStackLayout>
</ContentPage>