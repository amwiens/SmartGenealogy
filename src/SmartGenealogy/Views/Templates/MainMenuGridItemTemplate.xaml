<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SmartGenealogy.Views.Templates.MainMenuGridItemTemplate"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SmartGenealogy"
    xmlns:models="clr-namespace:SmartGenealogy.Models"
    xmlns:views="clr-namespace:SmartGenealogy.Views"
    x:DataType="models:MenuEntry">

    <Grid Margin="5,10" RowDefinitions="50, *">

        <Label
            FontFamily="MaterialDesign"
            FontSize="30"
            HorizontalOptions="Center"
            Text="{Binding Icon, Mode=OneWay}"
            TextColor="{DynamicResource White}"
            VerticalOptions="Center" />

        <Label
            Grid.Row="1"
            FontFamily="RegularFont"
            FontSize="13"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            Style="{DynamicResource Title2}"
            Text="{Binding Title, Mode=OneWay}"
            TextColor="{DynamicResource White}"
            VerticalOptions="Center" />
    </Grid>
</ContentView>