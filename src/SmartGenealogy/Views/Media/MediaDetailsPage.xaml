<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage
    x:Class="SmartGenealogy.Views.Media.MediaDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:SmartGenealogy.Views.Base"
    xmlns:fonticons="clr-namespace:SmartGenealogy.Resources.FontIcons"
    xmlns:localization="clr-namespace:SmartGenealogy.Resources.Translations"
    xmlns:viewModel="clr-namespace:SmartGenealogy.ViewModels.Media"
    x:Name="mediaDetailPage"
    x:DataType="viewModel:MediaDetailsPageViewModel"
    BackgroundColor="{DynamicResource BasePageColor}"
    BaseTitle=""
    BaseTitleColor="{StaticResource BaseTextColor}">

    <base:BasePage.PageContent>
        <Grid ColumnDefinitions="*,*">
            <Image
                Grid.Column="0"
                Aspect="AspectFit"
                Source="{Binding FilePath}" />

            <ScrollView Grid.Column="1">
                <VerticalStackLayout Padding="10">
                    <HorizontalStackLayout HorizontalOptions="End">
                        <Button
                            Command="{Binding EditFactTypeCommand}"
                            CornerRadius="14"
                            FontAttributes="Bold"
                            FontFamily="FaRegular"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Text="{x:Static fonticons:FaRegular.Edit}"
                            TextColor="{DynamicResource White}"
                            ToolTipProperties.Text="{localization:Translate ToolTipEdit}" />

                        <Button
                            Command="{Binding DeleteFactTypeCommand}"
                            CornerRadius="14"
                            FontAttributes="Bold"
                            FontFamily="FaRegular"
                            IsEnabled="{Binding IsBuiltIn, Converter={StaticResource InverseBooleanConverter}}"
                            Style="{StaticResource DeleteButtonStyle}"
                            Text="{x:Static fonticons:FaRegular.TrashAlt}"
                            TextColor="{DynamicResource White}"
                            ToolTipProperties.Text="{localization:Translate ToolTipDelete}" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding Caption}" />
                    <Label Text="{Binding RefNumber}" />
                    <Label Text="{Binding Date}" />
                    <Label Text="{Binding SortDate}" />
                    <Label Text="{Binding Description}" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </base:BasePage.PageContent>
</base:BasePage>