<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage
    x:Class="SmartGenealogy.Views.Media.MediaDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:SmartGenealogy.Views.Base"
    xmlns:viewModel="clr-namespace:SmartGenealogy.ViewModels.Media"
    x:Name="mediaDetailPage"
    x:DataType="viewModel:MediaDetailsPageViewModel"
    BackgroundColor="{DynamicResource MainWrapperBackgroundColor}"
    BaseTitle="MediaDetailsPage"
    BaseTitleColor="{StaticResource BaseTextColor}">

    <base:BasePage.PageContent>
        <VerticalStackLayout>
            <Label
                HorizontalOptions="Center"
                Text="Welcome to .NET MAUI!"
                VerticalOptions="Center" />
        </VerticalStackLayout>
    </base:BasePage.PageContent>
</base:BasePage>