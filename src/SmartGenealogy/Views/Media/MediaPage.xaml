<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage
    x:Class="SmartGenealogy.Views.Media.MediaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:SmartGenealogy.Views.Base"
    xmlns:viewModel="clr-namespace:SmartGenealogy.ViewModels.Media"
    x:DataType="viewModel:MediaPageViewModel"
    BaseTitle="{Binding Title}"
    BaseTitleColor="{StaticResource PrimaryColor}">

    <VerticalStackLayout Padding="30,0" Spacing="25">
        <Label
            SemanticProperties.HeadingLevel="Level1"
            Style="{StaticResource Headline}"
            Text="{Binding Title}" />
    </VerticalStackLayout>
</base:BasePage>