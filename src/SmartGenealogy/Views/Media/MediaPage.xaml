<?xml version="1.0" encoding="utf-8" ?>
<base:BasePage
    x:Class="SmartGenealogy.Views.Media.MediaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:SmartGenealogy.Views.Base"
    xmlns:controls="clr-namespace:SmartGenealogy.Controls"
    xmlns:converters="clr-namespace:SmartGenealogy.Converters"
    xmlns:fonticons="clr-namespace:SmartGenealogy.Resources.FontIcons"
    xmlns:localization="clr-namespace:SmartGenealogy.Resources.Translations"
    xmlns:models="clr-namespace:SmartGenealogy.Data.Models;assembly=SmartGenealogy.Data"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModel="clr-namespace:SmartGenealogy.ViewModels.Media"
    x:Name="mediaPage"
    x:DataType="viewModel:MediaPageViewModel"
    BackgroundColor="{DynamicResource BasePageColor}"
    BaseTitle="{localization:Translate MenuMedia}"
    BaseTitleColor="{StaticResource BaseTextColor}">

    <base:BasePage.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </base:BasePage.Resources>

    <base:BasePage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding Source={x:Reference mediaPage}, Path=BindingContext}"
            Command="{Binding AppearingCommand}"
            EventName="Appearing" />
    </base:BasePage.Behaviors>

    <base:BasePage.PageContent>
        <Grid RowDefinitions="Auto, *">
            <controls:LoadingIndicator
                Grid.Row="0"
                BackgroundColor="{DynamicResource BasePageColor}"
                HorizontalOptions="Center"
                IndicatorColor="{DynamicResource PrimaryColor}"
                IsBusy="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                LoadingText="{localization:Translate LabelLoading}"
                LoadingTextColor="{DynamicResource PrimaryColor}" />

            <HorizontalStackLayout Grid.Row="0" HorizontalOptions="End">
                <Button
                    Command="{Binding AddMultimediaCommand}"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    FontFamily="FaRegular"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Text="{x:Static fonticons:FaRegular.PlusSquare}"
                    TextColor="{DynamicResource White}"
                    ToolTipProperties.Text="{localization:Translate ToolTipAdd}" />
            </HorizontalStackLayout>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Multimedia}">

                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:Multimedia">
                            <StackLayout Margin="5" IsVisible="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}, Source={RelativeSource AncestorType={x:Type viewModel:MediaPageViewModel}}, x:DataType=viewModel:MediaPageViewModel}">
                                <!--  Manage multimedia  -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="40" />
                                    </Grid.ColumnDefinitions>

                                    <Image
                                        Grid.Column="0"
                                        Aspect="AspectFit"
                                        HeightRequest="100"
                                        Source="{Binding ThumbnailBytes}"
                                        WidthRequest="150" />

                                    <Label
                                        Grid.Column="1"
                                        FontSize="15"
                                        HorizontalOptions="Start"
                                        Text="{Binding Caption}"
                                        VerticalOptions="Center"
                                        VerticalTextAlignment="Center" />

                                    <Label
                                        Grid.Column="2"
                                        FontFamily="IonIcons"
                                        FontSize="15"
                                        HorizontalOptions="End"
                                        HorizontalTextAlignment="Center"
                                        Text="{x:Static fonticons:IonIcons.ChevronRight}"
                                        TextColor="{DynamicResource BaseIconColor}"
                                        VerticalOptions="Center" />

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenMediaDetailsCommand, Source={RelativeSource AncestorType={x:Type viewModel:MediaPageViewModel}}, x:DataType=viewModel:MediaPageViewModel}" CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                </Grid>

                                <Rectangle Fill="{DynamicResource BaseSeparatorColor}" HeightRequest="1" />
                            </StackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </base:BasePage.PageContent>
</base:BasePage>