<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SmartGenealogy.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SmartGenealogy.Controls"
    xmlns:fonticons="clr-namespace:SmartGenealogy.Resources.FontIcons"
    xmlns:localization="clr-namespace:SmartGenealogy.Resources.Translations"
    xmlns:main="clr-namespace:SmartGenealogy.Views.Main"
    xmlns:media="clr-namespace:SmartGenealogy.Views.Media"
    xmlns:settings="clr-namespace:SmartGenealogy.Views.Settings"
    xmlns:viewModels="clr-namespace:SmartGenealogy.ViewModels.Main"
    FlyoutBackgroundColor="{DynamicResource PrimaryColor}"
    FlyoutBehavior="{OnIdiom Desktop=Locked,
                             Default=Flyout}"
    FlyoutHeaderBehavior="Fixed"
    FlyoutWidth="315">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Shell.FlyoutHeader>
        <controls:FlyoutHeader />
    </Shell.FlyoutHeader>

    <Shell.FlyoutFooter>
        <controls:FlyoutFooter />
    </Shell.FlyoutFooter>

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid
                Padding="30,10"
                ColumnDefinitions="Auto,*"
                ColumnSpacing="20">
                <Image
                    HeightRequest="25"
                    HorizontalOptions="Start"
                    Source="{Binding FlyoutIcon}"
                    VerticalOptions="Center" />
                <Label
                    Grid.Column="1"
                    Style="{StaticResource Title2}"
                    Text="{Binding Title}"
                    TextColor="{DynamicResource White}"
                    VerticalTextAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <Shell.MenuItemTemplate>
        <DataTemplate>
            <Grid
                Padding="30,10"
                ColumnDefinitions="Auto,*"
                ColumnSpacing="20">
                <Image
                    HeightRequest="25"
                    HorizontalOptions="Start"
                    Source="{Binding FlyoutIcon}"
                    VerticalOptions="Center" />
                <Label
                    Grid.Column="1"
                    Style="{StaticResource Title2}"
                    Text="{Binding Title}"
                    TextColor="{StaticResource White}"
                    VerticalTextAlignment="Center" />
            </Grid>
        </DataTemplate>
    </Shell.MenuItemTemplate>

    <FlyoutItem Title="{localization:Translate MenuHome}" Icon="{FontImageSource FontFamily=FaPro, Glyph={x:Static fonticons:FaPro.Home}, Size=50, Color={StaticResource White}}">
        <ShellContent
            Title=""
            ContentTemplate="{DataTemplate main:MainPage}"
            Route="main" />
    </FlyoutItem>

    <FlyoutItem Title="{localization:Translate MenuMedia}" Icon="{FontImageSource FontFamily=FaPro, Glyph={x:Static fonticons:FaPro.Image}, Size=50, Color={StaticResource White}}">
        <ShellContent
            Title=""
            ContentTemplate="{DataTemplate media:MediaPage}"
            Route="media" />
    </FlyoutItem>

    <FlyoutItem Title="{localization:Translate MenuSettings}" Icon="{FontImageSource FontFamily=FaPro, Glyph={x:Static fonticons:FaPro.Cog}, Size=50, Color={StaticResource White}}">
        <ShellContent
            Title=""
            ContentTemplate="{DataTemplate settings:SettingsPage}"
            Route="settings" />
    </FlyoutItem>

</Shell>