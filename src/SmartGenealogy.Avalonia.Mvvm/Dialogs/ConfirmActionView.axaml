<UserControl x:Class="SmartGenealogy.Avalonia.Mvvm.ConfirmActionView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:glyphs="clr-namespace:SmartGenealogy.Avalonia.Controls.Glyphs;assembly=SmartGenealogy.Avalonia.Controls"
             xmlns:vm="clr-namespace:SmartGenealogy.Avalonia.Mvvm.Dialogs"
             x:DataType="vm:ConfirmActionViewModel"
             Background="Transparent">
  <Grid x:Name="OuterGrid"
        Margin="8"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Bottom"
        Opacity="0">

  </Grid>
</UserControl>